<div class="poff-filesystem-layout poff-filesystem-layout--{{kind}}">
    <style>
        .poff-filesystem-layout {
            --poff-fs-bg: #f3f6fb;
            --poff-fs-panel: #ffffff;
            --poff-fs-panel-strong: #eef3fb;
            --poff-fs-line: #cfd8e7;
            --poff-fs-line-dark: #aebbd3;
            --poff-fs-text: #1f2937;
            --poff-fs-text-soft: #5b677b;
            --poff-fs-title: #0f172a;
            --poff-fs-blue: #2563eb;
            --poff-fs-blue-soft: #dbeafe;
            --poff-fs-green: #0f766e;
            --poff-fs-shadow: 0 18px 40px rgba(148, 163, 184, 0.18);
            min-height: 100dvh;
            display: grid;
            grid-template-rows: auto auto 1fr;
            background:
                linear-gradient(180deg, rgba(255,255,255,0.9), rgba(240,244,251,0.96)),
                repeating-linear-gradient(90deg, rgba(148,163,184,0.06) 0, rgba(148,163,184,0.06) 1px, transparent 1px, transparent 24px);
            color: var(--poff-fs-text);
            font-family: "Segoe UI", "Lucida Grande", "Trebuchet MS", sans-serif;
        }

        .poff-filesystem-layout__topbar,
        .poff-filesystem-layout__toolbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.7rem 1rem;
            background: linear-gradient(180deg, #fbfdff, #edf3fb);
            border-bottom: 1px solid var(--poff-fs-line);
        }

        .poff-filesystem-layout__traffic {
            display: inline-flex;
            gap: 0.35rem;
            margin-right: 0.4rem;
        }

        .poff-filesystem-layout__traffic span {
            width: 0.72rem;
            height: 0.72rem;
            border-radius: 999px;
            border: 1px solid rgba(15, 23, 42, 0.12);
            background: linear-gradient(180deg, #ffffff, #dbe5f3);
        }

        .poff-filesystem-layout__crumbs {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            flex: 1 1 auto;
            min-width: 0;
            padding: 0.45rem 0.7rem;
            border: 1px solid var(--poff-fs-line);
            border-radius: 0.45rem;
            background: var(--poff-fs-panel);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.9);
            font-size: 0.92rem;
            color: var(--poff-fs-text-soft);
        }

        .poff-filesystem-layout__crumbs strong {
            color: var(--poff-fs-title);
            font-weight: 600;
        }

        .poff-filesystem-layout__search {
            min-width: 12rem;
            padding: 0.45rem 0.75rem;
            border: 1px solid var(--poff-fs-line);
            border-radius: 999px;
            background: rgba(255,255,255,0.9);
            color: var(--poff-fs-text-soft);
            font-size: 0.84rem;
            white-space: nowrap;
        }

        .poff-filesystem-layout__toolbar {
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .poff-filesystem-layout__toolbar-group {
            display: inline-flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .poff-filesystem-layout__button {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.42rem 0.72rem;
            border: 1px solid var(--poff-fs-line);
            border-radius: 0.4rem;
            background: linear-gradient(180deg, #ffffff, #eef3fb);
            font-size: 0.82rem;
            color: var(--poff-fs-text);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.92);
        }

        .poff-filesystem-layout__button--accent {
            border-color: #9dbcf6;
            background: linear-gradient(180deg, #eff6ff, #dbeafe);
            color: #1849b7;
        }

        .poff-filesystem-layout__workspace {
            display: grid;
            grid-template-columns: minmax(13rem, 16rem) minmax(0, 1fr);
            min-height: 0;
            padding: 1rem;
            gap: 1rem;
        }

        .poff-filesystem-layout__sidebar,
        .poff-filesystem-layout__content {
            min-height: 0;
            border: 1px solid var(--poff-fs-line);
            border-radius: 0.75rem;
            background: var(--poff-fs-panel);
            box-shadow: var(--poff-fs-shadow);
            overflow: hidden;
        }

        .poff-filesystem-layout__sidebar {
            background:
                linear-gradient(180deg, #fdfefe 0%, #f4f7fc 100%);
        }

        .poff-filesystem-layout__sidebar-head,
        .poff-filesystem-layout__content-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.9rem 1rem;
            border-bottom: 1px solid var(--poff-fs-line);
            background: linear-gradient(180deg, #fbfdff, #eef3fb);
        }

        .poff-filesystem-layout__sidebar-title,
        .poff-filesystem-layout__content-title {
            margin: 0;
            font-size: 0.86rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--poff-fs-text-soft);
        }

        .poff-filesystem-layout__meta {
            display: grid;
            gap: 0.25rem;
            font-size: 0.8rem;
            color: var(--poff-fs-text-soft);
        }

        .poff-filesystem-layout__meta strong {
            color: var(--poff-fs-title);
            font-size: 1.1rem;
            letter-spacing: -0.03em;
        }

        .poff-filesystem-layout__tree {
            padding: 0.8rem;
            display: grid;
            gap: 0.35rem;
        }

        .poff-filesystem-layout__tree-item {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.55rem 0.7rem;
            border-radius: 0.55rem;
            color: var(--poff-fs-text);
            font-size: 0.92rem;
        }

        .poff-filesystem-layout__tree-item strong {
            font-weight: 600;
        }

        .poff-filesystem-layout__tree-item--active {
            background: var(--poff-fs-blue-soft);
            color: #1d4ed8;
            outline: 1px solid rgba(37,99,235,0.14);
        }

        .poff-filesystem-layout__content-headline {
            display: grid;
            gap: 0.25rem;
        }

        .poff-filesystem-layout__content-headline h1 {
            margin: 0;
            font-size: clamp(1.3rem, 2.2vw, 2rem);
            color: var(--poff-fs-title);
            letter-spacing: -0.04em;
        }

        .poff-filesystem-layout__content-headline p {
            margin: 0;
            color: var(--poff-fs-text-soft);
            max-width: 48rem;
        }

        .poff-filesystem-layout__content-body {
            min-height: 0;
            padding: 1rem;
            overflow: auto;
            background:
                linear-gradient(180deg, rgba(255,255,255,0.86), rgba(247,250,253,0.96));
        }

        .poff-filesystem-layout__content-body > * {
            width: 100%;
            max-width: 100%;
            box-sizing: border-box;
        }

        .poff-filesystem-layout .folder-view {
            gap: 0;
        }

        .poff-filesystem-layout .folder-view-summary {
            padding: 0.6rem 0.85rem;
            margin-bottom: 0.8rem;
            border: 1px solid var(--poff-fs-line);
            border-radius: 0.5rem;
            background: var(--poff-fs-panel-strong);
            color: var(--poff-fs-text-soft);
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .poff-filesystem-layout .folder-view-grid {
            gap: 0;
            border: 1px solid var(--poff-fs-line);
            border-radius: 0.6rem;
            overflow: hidden;
            background: #fff;
            grid-template-columns: 1fr;
        }

        .poff-filesystem-layout .folder-view-card {
            position: relative;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: center;
            gap: 1rem;
            padding: 0.85rem 1rem;
            border: 0;
            border-bottom: 1px solid #e6edf7;
            border-radius: 0;
            background: transparent;
            box-shadow: none;
        }

        .poff-filesystem-layout .folder-view-card:last-child {
            border-bottom: 0;
        }

        .poff-filesystem-layout .folder-view-card:hover {
            background: #f7fbff;
        }

        .poff-filesystem-layout .folder-view-card::before {
            content: attr(data-kind);
            justify-self: end;
            min-width: 5.6rem;
            padding: 0.24rem 0.5rem;
            border-radius: 999px;
            background: #edf4ff;
            color: #3158a5;
            font-size: 0.72rem;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .poff-filesystem-layout .folder-view-card[data-kind="folder"]::before {
            background: #ecfeff;
            color: var(--poff-fs-green);
        }

        .poff-filesystem-layout .folder-view-card__title,
        .poff-filesystem-layout .folder-view-card a,
        .poff-filesystem-layout .folder-view-card h3 {
            color: var(--poff-fs-title);
        }

        .poff-filesystem-layout img,
        .poff-filesystem-layout video,
        .poff-filesystem-layout iframe,
        .poff-filesystem-layout canvas,
        .poff-filesystem-layout svg {
            display: block;
            max-width: 100%;
            max-height: calc(100dvh - 18rem);
            margin-inline: auto;
            box-shadow: 0 12px 28px rgba(148, 163, 184, 0.18);
            border-radius: 0.5rem;
            background: #fff;
        }

        @media (max-width: 900px) {
            .poff-filesystem-layout__workspace {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            .poff-filesystem-layout__topbar,
            .poff-filesystem-layout__toolbar,
            .poff-filesystem-layout__workspace {
                padding-left: 0.75rem;
                padding-right: 0.75rem;
            }

            .poff-filesystem-layout__search {
                min-width: 0;
                width: 100%;
            }
        }
    </style>

    <header class="poff-filesystem-layout__topbar">
        <div class="poff-filesystem-layout__traffic" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
        </div>
        <div class="poff-filesystem-layout__crumbs">
            <span>C:\</span>
            <span>Users\</span>
            <span>eggman\</span>
            <strong>{{title}}</strong>
        </div>
        <div class="poff-filesystem-layout__search">search {{name}}</div>
    </header>

    <div class="poff-filesystem-layout__toolbar">
        <div class="poff-filesystem-layout__toolbar-group">
            <span class="poff-filesystem-layout__button poff-filesystem-layout__button--accent">New Folder</span>
            <span class="poff-filesystem-layout__button">Sort</span>
            <span class="poff-filesystem-layout__button">View</span>
            <span class="poff-filesystem-layout__button">Inspect</span>
        </div>
        <div class="poff-filesystem-layout__toolbar-group">
            <span class="poff-filesystem-layout__button">Nerd Mode</span>
            <span class="poff-filesystem-layout__button">Details</span>
        </div>
    </div>

    <div class="poff-filesystem-layout__workspace">
        <aside class="poff-filesystem-layout__sidebar">
            <div class="poff-filesystem-layout__sidebar-head">
                <p class="poff-filesystem-layout__sidebar-title">Tree</p>
                <div class="poff-filesystem-layout__meta">
                    <span>layout</span>
                    <strong>filesystem</strong>
                </div>
            </div>
            <div class="poff-filesystem-layout__tree">
                <div class="poff-filesystem-layout__tree-item"><span>></span><strong>Desktop</strong></div>
                <div class="poff-filesystem-layout__tree-item"><span>></span><strong>Projects</strong></div>
                <div class="poff-filesystem-layout__tree-item poff-filesystem-layout__tree-item--active"><span>></span><strong>{{title}}</strong></div>
                <div class="poff-filesystem-layout__tree-item"><span>></span><strong>.layout</strong></div>
                <div class="poff-filesystem-layout__tree-item"><span>></span><strong>assets</strong></div>
            </div>
        </aside>

        <section class="poff-filesystem-layout__content">
            <div class="poff-filesystem-layout__content-head">
                <div class="poff-filesystem-layout__content-headline">
                    <h1>{{title}}</h1>
                    {{#if description}}
                        <p>{{description}}</p>
                    {{else}}
                        <p>Filesystem view with a bright Explorer-style shell, column-like listing, and visible structure around the current work.</p>
                    {{/if}}
                </div>
                <div class="poff-filesystem-layout__meta">
                    <span>{{#if isFolder}}Directory{{else}}File{{/if}}</span>
                    <strong>{{name}}</strong>
                </div>
            </div>
            <div class="poff-filesystem-layout__content-body">
                {{#if isFolder}}
                    {{> works}}
                {{else}}
                    {{> work}}
                {{/if}}
            </div>
        </section>
    </div>

    <script>
        document.documentElement.dataset.poffFilesystemLayout = 'active';
        document.querySelectorAll('.poff-filesystem-layout .folder-view-card').forEach((card) => {
            const href = card.querySelector('a')?.getAttribute('href') || '';
            card.dataset.kind = href.includes('?view=1&file=') ? 'file' : 'folder';
        });
    </script>
</div>
