<div class="poff-filesystem-layout poff-filesystem-layout--{{kind}} flex min-h-screen flex-col bg-gradient-to-b from-white to-slate-100 text-slate-800">
    <header class="poff-filesystem-layout__topbar flex flex-wrap items-center gap-3 border-b border-slate-300 bg-gradient-to-b from-white to-slate-100 px-3 py-2.5 md:px-4">
        <div class="poff-filesystem-layout__traffic mr-1 inline-flex gap-1.5" aria-hidden="true">
            <span class="h-3 w-3 rounded-full border border-slate-900/10 bg-gradient-to-b from-white to-slate-200"></span>
            <span class="h-3 w-3 rounded-full border border-slate-900/10 bg-gradient-to-b from-white to-slate-200"></span>
            <span class="h-3 w-3 rounded-full border border-slate-900/10 bg-gradient-to-b from-white to-slate-200"></span>
        </div>
        <div class="poff-filesystem-layout__crumbs flex min-w-0 flex-1 items-center gap-2 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-500 shadow-inner">
            <span>C:\</span>
            <span>Users\</span>
            <span>eggman\</span>
            <strong class="font-semibold text-slate-900">{{title}}</strong>
        </div>
        <div class="poff-filesystem-layout__search w-full whitespace-nowrap rounded-full border border-slate-300 bg-white/90 px-3 py-2 text-sm text-slate-500 md:w-auto md:min-w-48">search {{name}}</div>
    </header>

    <div class="poff-filesystem-layout__toolbar flex flex-wrap items-center justify-between gap-3 border-b border-slate-300 bg-gradient-to-b from-white to-slate-100 px-3 py-2.5 md:px-4">
        <div class="poff-filesystem-layout__toolbar-group inline-flex flex-wrap gap-2">
            <span class="poff-filesystem-layout__button poff-filesystem-layout__button--accent inline-flex items-center rounded-md border border-blue-300 bg-blue-50 px-3 py-1.5 text-sm text-blue-800 shadow-inner">New Folder</span>
            <span class="poff-filesystem-layout__button inline-flex items-center rounded-md border border-slate-300 bg-gradient-to-b from-white to-slate-100 px-3 py-1.5 text-sm text-slate-700 shadow-inner">Sort</span>
            <span class="poff-filesystem-layout__button inline-flex items-center rounded-md border border-slate-300 bg-gradient-to-b from-white to-slate-100 px-3 py-1.5 text-sm text-slate-700 shadow-inner">View</span>
            <span class="poff-filesystem-layout__button inline-flex items-center rounded-md border border-slate-300 bg-gradient-to-b from-white to-slate-100 px-3 py-1.5 text-sm text-slate-700 shadow-inner">Inspect</span>
        </div>
        <div class="poff-filesystem-layout__toolbar-group inline-flex flex-wrap gap-2">
            <span class="poff-filesystem-layout__button inline-flex items-center rounded-md border border-slate-300 bg-gradient-to-b from-white to-slate-100 px-3 py-1.5 text-sm text-slate-700 shadow-inner">Nerd Mode</span>
            <span class="poff-filesystem-layout__button inline-flex items-center rounded-md border border-slate-300 bg-gradient-to-b from-white to-slate-100 px-3 py-1.5 text-sm text-slate-700 shadow-inner">Details</span>
        </div>
    </div>

    <div class="poff-filesystem-layout__workspace grid min-h-0 flex-1 grid-cols-1 gap-4 p-3 md:p-4 lg:grid-cols-12">
        <aside class="poff-filesystem-layout__sidebar min-h-0 overflow-hidden rounded-xl border border-slate-300 bg-gradient-to-b from-white to-slate-100 shadow-xl lg:col-span-3">
            <div class="poff-filesystem-layout__sidebar-head flex items-center justify-between gap-3 border-b border-slate-300 bg-gradient-to-b from-white to-slate-100 px-4 py-3.5">
                <p class="poff-filesystem-layout__sidebar-title m-0 text-xs uppercase tracking-wider text-slate-500">Tree</p>
                <div class="poff-filesystem-layout__meta grid gap-1 text-xs text-slate-500">
                    <span>layout</span>
                    <strong class="text-base text-slate-900">filesystem</strong>
                </div>
            </div>
            <div class="poff-filesystem-layout__tree grid gap-1.5 p-3">
                <div class="poff-filesystem-layout__tree-item flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-700"><span>></span><strong class="font-semibold">Desktop</strong></div>
                <div class="poff-filesystem-layout__tree-item flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-700"><span>></span><strong class="font-semibold">Projects</strong></div>
                <div class="poff-filesystem-layout__tree-item poff-filesystem-layout__tree-item--active flex items-center gap-2 rounded-lg bg-blue-100 px-3 py-2 text-sm text-blue-700 outline outline-1 outline-blue-600/15"><span>></span><strong class="font-semibold">{{title}}</strong></div>
                <div class="poff-filesystem-layout__tree-item flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-700"><span>></span><strong class="font-semibold">.layout</strong></div>
                <div class="poff-filesystem-layout__tree-item flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-slate-700"><span>></span><strong class="font-semibold">assets</strong></div>
            </div>
        </aside>

        <section class="poff-filesystem-layout__content min-h-0 overflow-hidden rounded-xl border border-slate-300 bg-white shadow-xl lg:col-span-9">
            <div class="poff-filesystem-layout__content-head flex items-center justify-between gap-3 border-b border-slate-300 bg-gradient-to-b from-white to-slate-100 px-4 py-3.5">
                <div class="poff-filesystem-layout__content-headline grid gap-1">
                    <h1 class="m-0 text-2xl text-slate-900">{{title}}</h1>
                    {{#if description}}
                        <p class="m-0 max-w-3xl text-slate-500">{{description}}</p>
                    {{else}}
                        <p class="m-0 max-w-3xl text-slate-500">Filesystem view with a bright Explorer-style shell, column-like listing, and visible structure around the current work.</p>
                    {{/if}}
                </div>
                <div class="poff-filesystem-layout__meta grid gap-1 text-xs text-slate-500">
                    <span>{{#if isFolder}}Directory{{else}}File{{/if}}</span>
                    <strong class="text-base text-slate-900">{{name}}</strong>
                </div>
            </div>
            <div class="poff-filesystem-layout__content-body min-h-0 overflow-auto bg-gradient-to-b from-white to-slate-50 p-4">
                {{#if isFolder}}
                    {{> works}}
                {{else}}
                    {{> work}}
                {{/if}}
            </div>
        </section>
    </div>

    <script>
        document.documentElement.dataset.poffFilesystemLayout = 'active';
        document.querySelectorAll('.poff-filesystem-layout .folder-view-card').forEach((card) => {
            const href = card.querySelector('a')?.getAttribute('href') || '';
            card.dataset.kind = href.includes('?view=1&file=') ? 'file' : 'folder';
        });
    </script>
</div>
