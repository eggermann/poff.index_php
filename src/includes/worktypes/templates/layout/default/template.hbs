<div class="poff-default-layout poff-default-layout--{{kind}}">
    <aside class="poff-default-layout__sidebar">
        <nav class="poff-default-layout__nav" aria-label="Current work navigation">
            {{#if parentPageLink}}
                <a class="poff-default-layout__nav-link poff-default-layout__nav-link--up" href="{{parentPageLink}}">
                    <span class="poff-default-layout__nav-icon">↑</span>
                    <span class="poff-default-layout__nav-name">Go Up</span>
                </a>
            {{/if}}

            {{#if showDirectoryPageLink}}
                <a class="poff-default-layout__nav-link {{#if isFolder}}poff-default-layout__nav-link--current{{/if}}" href="{{directoryPageLink}}">
                    <span class="poff-default-layout__nav-icon">./</span>
                    <span class="poff-default-layout__nav-name">{{name}}</span>
                </a>
            {{/if}}

            {{#if isFolder}}
                {{#each items}}
                    <a class="poff-default-layout__nav-link" href="{{pageLink}}">
                        <span class="poff-default-layout__nav-icon">{{#if isFolder}}▣{{else}}◧{{/if}}</span>
                        <span class="poff-default-layout__nav-name">{{name}}</span>
                    </a>
                {{/each}}
            {{else}}
                <a class="poff-default-layout__nav-link poff-default-layout__nav-link--current" href="{{pageLink}}">
                    <span class="poff-default-layout__nav-icon">◧</span>
                    <span class="poff-default-layout__nav-name">{{name}}</span>
                </a>
            {{/if}}
        </nav>
    </aside>

    <div class="poff-default-layout__stage">
        <header class="poff-default-layout__header">
            <div class="poff-default-layout__header-copy">
                <p class="poff-default-layout__eyebrow">{{#if isFolder}}Folder{{else}}Work{{/if}} Shell</p>
                <h1 class="poff-default-layout__title">{{title}}</h1>
                {{#if description}}
                    <p class="poff-default-layout__description">{{description}}</p>
                {{/if}}
            </div>
            <div class="poff-default-layout__header-actions">
                <div class="poff-default-layout__status-pill">Smart Mode Active</div>
                <div class="poff-default-layout__meta-chip">{{#if isFolder}}{{itemCount}} entries{{else}}{{kind}}{{/if}}</div>
                <button class="poff-default-layout__action poff-default-layout__action--sync" type="button" data-layout-sync>Sync</button>
                <button class="poff-default-layout__action" type="button" data-layout-toggle>Toggle Panel</button>
            </div>
        </header>

        <section class="poff-default-layout__insights" aria-label="Smart app overview">
            <article class="poff-default-layout__metric-card">
                <span class="poff-default-layout__metric-label">Scope</span>
                <strong class="poff-default-layout__metric-value">{{#if isFolder}}Folder{{else}}File{{/if}}</strong>
            </article>
            <article class="poff-default-layout__metric-card">
                <span class="poff-default-layout__metric-label">Visible</span>
                <strong class="poff-default-layout__metric-value">{{#if isFolder}}{{itemCount}}{{else}}1{{/if}}</strong>
            </article>
            <article class="poff-default-layout__metric-card">
                <span class="poff-default-layout__metric-label">Total Assets</span>
                <strong class="poff-default-layout__metric-value">{{#if isFolder}}{{#if allItemCount}}{{allItemCount}}{{else}}{{itemCount}}{{/if}}{{else}}1{{/if}}</strong>
            </article>
            <article class="poff-default-layout__metric-card poff-default-layout__metric-card--time">
                <span class="poff-default-layout__metric-label">Last Sync</span>
                <strong class="poff-default-layout__metric-value" data-layout-last-sync>now</strong>
            </article>

            <aside class="poff-default-layout__activity-panel">
                <h2 class="poff-default-layout__activity-title">Next Focus</h2>
                {{#if isFolder}}
                    {{#if hasItems}}
                        <ul class="poff-default-layout__activity-list">
                            {{#each items}}
                                <li class="poff-default-layout__activity-item">
                                    <span class="poff-default-layout__activity-kind">{{#if isFolder}}Folder{{else}}File{{/if}}</span>
                                    <a href="{{pageLink}}" class="poff-default-layout__activity-link">{{name}}</a>
                                </li>
                            {{/each}}
                        </ul>
                    {{else}}
                        <p class="poff-default-layout__activity-empty">No entries available yet.</p>
                    {{/if}}
                {{else}}
                    <ul class="poff-default-layout__activity-list">
                        <li class="poff-default-layout__activity-item">
                            <span class="poff-default-layout__activity-kind">Type</span>
                            <span class="poff-default-layout__activity-link">{{kind}}</span>
                        </li>
                        <li class="poff-default-layout__activity-item">
                            <span class="poff-default-layout__activity-kind">Name</span>
                            <span class="poff-default-layout__activity-link">{{name}}</span>
                        </li>
                        <li class="poff-default-layout__activity-item">
                            <span class="poff-default-layout__activity-kind">Path</span>
                            <span class="poff-default-layout__activity-link">{{path}}</span>
                        </li>
                    </ul>
                {{/if}}
            </aside>
        </section>

        <main class="poff-default-layout__main">
            {{#if isFolder}}
                {{> works}}
            {{else}}
                {{> work}}
            {{/if}}
        </main>

        <footer class="poff-default-layout__footer">
            <span>{{#if isFolder}}Directory{{else}}File{{/if}}: {{name}}</span>
        </footer>
    </div>
</div>
