<div class="external-work external-work--embedded" style="border: 2px solid #dc2626; border-radius: 16px; padding: 16px; background: rgba(220, 38, 38, 0.04);">
    <style>
        .external-work--embedded {
            display: grid;
            gap: 0.875rem;
        }

        .external-work--embedded__toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .external-work--embedded__title {
            margin: 0;
            font-size: 0.92rem;
            font-weight: 600;
            letter-spacing: 0.02em;
            color: #e2e8f0;
        }

        .external-work--embedded__direct-link {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.45rem 0.8rem;
            border-radius: 999px;
            border: 1px solid rgba(248, 113, 113, 0.45);
            background: rgba(15, 23, 42, 0.86);
            color: #fecaca;
            text-decoration: none;
            font-size: 0.8rem;
            line-height: 1;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .external-work--embedded .external-work__body--rendered {
            background: #0f172a;
            border-radius: 12px;
            overflow: hidden;
        }

        .external-work--embedded .external-work__body--rendered #appShell,
        .external-work--embedded .external-work__body--rendered .main-content,
        .external-work--embedded .external-work__body--rendered #preview {
            background: transparent !important;
        }

        .external-work--embedded .external-work__body--rendered #contentFrame {
            background: #0b1220 !important;
            min-height: 65vh;
        }

        .external-work--embedded .external-work__body--rendered > * {
            width: 100% !important;
            max-width: 100% !important;
            box-sizing: border-box;
        }

        .external-work--embedded .external-work__body--rendered img,
        .external-work--embedded .external-work__body--rendered video,
        .external-work--embedded .external-work__body--rendered iframe,
        .external-work--embedded .external-work__body--rendered canvas,
        .external-work--embedded .external-work__body--rendered svg,
        .external-work--embedded .external-work__body--rendered picture {
            display: block;
            width: 100% !important;
            max-width: 100% !important;
            height: auto !important;
            margin-inline: auto;
        }
    </style>
    <div class="external-work--embedded__toolbar">
        <div>
            <div class="external-work--embedded__title">{{title}}</div>
            {{#if external.relation}}
                <div class="small-note">Generated relation: {{external.relation}}</div>
            {{/if}}
        </div>
        {{#if linkUrl}}
            <a class="external-work--embedded__direct-link" href="{{linkUrl}}" target="{{work.target}}" rel="noopener noreferrer">Direct link</a>
        {{/if}}
    </div>
    {{#if renderedHtml}}
        <div class="external-work__body external-work__body--rendered">
            {{{renderedHtml}}}
        </div>
    {{else}}
        {{#if previewUrl}}
            <iframe class="external-work__body external-work__body--iframe min-h-screen w-full rounded-md bg-slate-300" src="{{previewUrl}}" title="{{title}}"></iframe>
        {{else}}
            {{#if external.resultWork.srcUrl}}
                <figure class="external-work__body external-work__body--generated">
                    <img src="{{assetUrl}}" alt="{{title}}">
                    <figcaption>
                        Converted from {{external.sourceWork.path}} via {{external.generatedBy.id}}.
                    </figcaption>
                </figure>
            {{else}}
                <div class="external-work__body external-work__body--message message">
                    <div class="mb-3">External link</div>
                    <a href="{{linkUrl}}" target="{{work.target}}" rel="noopener">{{linkUrl}}</a>
                </div>
            {{/if}}
        {{/if}}
    {{/if}}
</div>
