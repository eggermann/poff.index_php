{
  "type": "converter",
  "name": "convert-image",
  "label": "Convert Image",
  "accepts": ["image/tiff", "image/*"],
  "outputs": ["image/webp", "image/jpeg", "image/png"],
  "engine": "imagemagick",
  "defaults": {
    "format": "webp",
    "quality": "default",
    "saveMode": "new-hidden-work",
    "hiddenByDefault": true
  },
  "ui": {
    "format": {
      "type": "select",
      "label": "Output format",
      "options": ["webp", "jpeg", "png"]
    },
    "quality": {
      "type": "select",
      "label": "Quality",
      "options": ["preview", "default", "archival", "small-web"]
    }
  }
}
